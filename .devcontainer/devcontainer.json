{
  "name": "MCP Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "postCreateCommand": "pip install -r requirements.txt",
  "postStartCommand": "mcp run server.py --transport sse",

  "forwardPorts": [8000],

  "portsAttributes": {
    "8000": {
      "label": "MCP Server",
      "onAutoForward": "openPreview",
      "visibility": "public"
    },
    "*": {
      "visibility": "public",
      "onAutoForward": "openPreview"
    }
  }
}
